PORT=8080
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,LTCUSDT,AVAXUSDT,TRXUSDT,DOTUSDT,ETCUSDT,LINKUSDT,UNIUSDT,ATOMUSDT,BCHUSDT,XLMUSDT,SUIUSDT,TONUSDT,SHIBUSDT
REST_POLL_INTERVAL_MS=15000
USE_MOCK_DATA=false
MARKET_STORE_DRIVER=memory
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=crypta
REDIS_TICK_TTL_MS=60000
ENABLE_MARKET_INGESTION=true
# Optional: public URL used for report share links.
# For local demo with Cloudflare Quick Tunnel, paste the https://*.trycloudflare.com URL here.
PUBLIC_BASE_URL=""

# Optional: persistence in PostgreSQL
ENABLE_DB_PERSISTENCE=true
SNAPSHOT_INTERVAL_MS=5000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crypta_db?schema=public"

# Optional: client auth (register/login)
JWT_SECRET="super_secret_change_me"
# Optional: owner-only users panel
ADMIN_VIEW_KEY="owner_secret_2026"
# Optional: secure password reset via email code (Resend SMTP example)
AUTH_RESET_SMTP_HOST="smtp.resend.com"
AUTH_RESET_SMTP_PORT=465
AUTH_RESET_SMTP_SECURE=true
AUTH_RESET_SMTP_USER="resend"
AUTH_RESET_SMTP_FROM="CryptoAggregator Security <onboarding@resend.dev>"
# Optional reply-to for support requests
AUTH_RESET_SMTP_REPLY_TO="support@yourdomain.com"
# Leave auth mode empty for classic SMTP login
AUTH_RESET_SMTP_AUTH_MODE=""
# Resend SMTP uses your API key as the password
AUTH_RESET_SMTP_PASS="paste_your_resend_api_key_here"
# OAuth2 fields are not needed for Resend SMTP
AUTH_RESET_SMTP_OAUTH_CLIENT_ID=""
AUTH_RESET_SMTP_OAUTH_CLIENT_SECRET=""
AUTH_RESET_SMTP_OAUTH_REFRESH_TOKEN=""
AUTH_RESET_SMTP_OAUTH_ACCESS_TOKEN=""
# Keep browser Gmail mode disabled when using server-side SMTP
AUTH_RESET_BROWSER_GMAIL=false
AUTH_RESET_ALLOW_CONSOLE_FALLBACK=true
AUTH_RESET_CODE_TTL_MS=600000
AUTH_RESET_COOLDOWN_MS=60000
AUTH_RESET_MAX_ATTEMPTS=5
