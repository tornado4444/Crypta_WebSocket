{
  "name": "crypta_websocket",
  "version": "1.0.0",
  "description": "Diploma MVP: crypto market data aggregation and normalization service with REST/WebSocket",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "test": "echo \"No tests yet\"",
    "auth:google-oauth2": "node scripts/get-google-oauth2-refresh-token.mjs",
    "public:tunnel": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-public-tunnel.ps1",
    "public:tunnel:no-app": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-public-tunnel.ps1 -NoApp",
    "host:public": "npm run public:tunnel",
    "domain:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-domain-tunnel.ps1",
    "domain:setup:window": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/open-domain-setup-window.ps1",
    "domain:tunnel": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-domain-tunnel.ps1",
    "domain:tunnel:no-app": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-domain-tunnel.ps1 -NoApp",
    "domain:tunnel:window": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/open-domain-tunnel-window.ps1",
    "domain:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-domain-hosting.ps1",
    "host:domain": "npm run domain:tunnel"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "6.16.2",
    "@types/pdfkit": "^0.17.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0",
    "redis": "^4.7.1",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "prisma": "6.16.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
